-- Save text
saveBtn.MouseButton1Click:Connect(function()
    savedText = textBox.Text
    
    -- Simpan ke dalam player untuk persistensi
    if not player:FindFirstChild("SellerNotes") then
        local noteValue = Instance.new("StringValue")
        noteValue.Name = "SellerNotes"
        noteValue.Value = savedText
        noteValue.Parent = player
    else
        player.SellerNotes.Value = savedText
    end
    
    -- Feedback visual
    saveBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    wait(0.2)
    saveBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
end)

-- Load text
loadBtn.MouseButton1Click:Connect(function()
    if player:FindFirstChild("SellerNotes") then
        textBox.Text = player.SellerNotes.Value
    else
        textBox.Text = "Belum ada catatan tersimpan!"
    end
    
    -- Feedback visual
    loadBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    wait(0.2)
    loadBtn.BackgroundColor3 = Color3.fromRGB(100, 180, 100)
end)

