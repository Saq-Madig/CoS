end)

-- Font size changer
local fontSizes = {14, 16, 18, 20, 22, 24, 26, 28, 30}
local currentFontIndex = 1

fontSizeSlider.MouseButton1Click:Connect(function()
    currentFontIndex = currentFontIndex + 1
    if currentFontIndex > #fontSizes then
        currentFontIndex = 1
    end
    
    local newSize = fontSizes[currentFontIndex]
    fontSizeSlider.Text = tostring(newSize)
    textBox.TextScaled = false
    textBox.TextSize = newSize
end)

-- Auto-save setiap 30 detik
spawn(function()
    while screenGui.Parent do
        wait(30)
        if player:FindFirstChild("SellerNotes") then
            player.SellerNotes.Value = textBox.Text
        else
            local noteValue = Instance.new("StringValue")
            noteValue.Name = "SellerNotes"
            noteValue.Value = textBox.Text
            noteValue.Parent = player
        end
    end
end)

