-- Fungsi untuk drag (mobile friendly)
local function startDrag(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end

local function onDrag(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        local newPosition = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X,
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
        mainFrame.Position = newPosition
    end
end

local function endDrag()
    dragging = false
end

-- Fungsi untuk resize (mobile friendly)
local function startResize(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        dragStart = input.Position
        startSize = mainFrame.Size
        startPos = mainFrame.Position
    end
end

local function onResize(input)
    if resizing and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        
        -- Minimal size
        local newWidth = math.max(200, startSize.X.Offset + delta.X)
        local newHeight = math.max(300, startSize.Y.Offset + delta.Y)
        
        mainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        
        -- Adjust text size scaling
        textBox.TextScaled = true
    end
end

local function endResize()
    resizing = false
end

-- Connect touch events untuk drag
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)

titleBar.InputChanged:Connect(function(input)
    onDrag(input)
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        endDrag()
    end
end)

-- Connect touch events untuk resize
resizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        startResize(input)
    end
end)

resizeHandle.InputChanged:Connect(function(input)
    onResize(input)
end)

resizeHandle.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        endResize()
    end
end)

-- Minimize function
minimizeBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    
    if isMinimized then
        mainFrame.Size = UDim2.new(0, 300, 0, 40)
        notepadArea.Visible = false
        toolbar.Visible = false
        resizeHandle.Visible = false
        minimizeBtn.Text = "□"
    else
        mainFrame.Size = originalSize
        notepadArea.Visible = true
        toolbar.Visible = true
        resizeHandle.Visible = true
        minimizeBtn.Text = "−"
    end
end)

